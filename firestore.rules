rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: האם המשתמש מחובר? ──
    function isAuth() {
      return request.auth != null;
    }

    // ── Helper: האם זה האדמין? ──
    function isAdmin() {
      return request.auth != null
          && (request.auth.token.email == 'amitdovrat123@gmail.com'
           || request.auth.token.email == 'viki.golkov1@gmail.com');
    }

    // ── Helper: האם זה בעל המידע? ──
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ══════════════════════════════════════════════════════
    //  PUBLIC DATA — נתונים ציבוריים (מוצרים, גלריה וכו')
    // ══════════════════════════════════════════════════════
    match /artifacts/{appId}/public/data/{document=**} {

      // תיקון קריטי: הרשאה לגלריית הסדנאות
      match /workshopGallery/{docId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // מוצרים: כולם רואים, רק אדמין משנה
      match /products/{productId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      // סדנאות (מידע שיווקי): כולם רואים, רק אדמין משנה
      match /workshops/{workshopId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      // באנר הודעות: כולם רואים
      match /bannerMessages/{messageId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      // הזמנות: רק המזמין או האדמין יכולים לראות/ליצור
      match /orders/{orderId} {
        allow read:  if isAdmin()
                     || (isAuth() && resource.data.userId == request.auth.uid);
        allow create: if isAuth();
        allow update, delete: if isAdmin();
      }

      // קופונים: רק משתמשים מחוברים רואים, רק אדמין יוצר
      match /coupons/{couponId} {
        allow read:  if isAuth();
        allow write: if isAdmin();

        match /userUsage/{usageId} {
          allow read:  if isAuth();
          allow create: if isAuth();
          allow update, delete: if isAdmin();
        }
      }

      // פניות שירות: validation בסיסי למניעת ספאם
      match /inquiries/{inquiryId} {
        allow create: if request.resource.data.keys().hasAll(['name', 'phone'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 1
                      && request.resource.data.name.size() < 100
                      && request.resource.data.phone is string
                      && request.resource.data.phone.size() > 8
                      && request.resource.data.phone.size() < 20
                      && request.resource.data.keys().size() < 12;
        allow read, update, delete: if isAdmin();
      }

      // לוגים: רק אדמין קורא, validation בסיסי
      match /logs/{logId} {
        allow create: if request.resource.data.keys().size() < 10
                      && request.resource.data.size() < 5000;
        allow read:   if isAdmin();
        allow update, delete: if false;
      }

      // הגדרות מערכת: רק אדמין
      match /settings/{settingId} {
        allow read, write: if isAdmin();
      }

      // הוצאות: רק אדמין
      match /expenses/{expenseId} {
        allow read, write: if isAdmin();
      }

      // תבניות WhatsApp: רק אדמין
      match /waTemplates/{templateId} {
        allow read, write: if isAdmin();
      }

      // תעבורת אתר: validation למניעת הצפה
      match /site_traffic/{docId} {
        allow create: if request.resource.data.keys().hasAll(['sessionId', 'event', 'page'])
                      && request.resource.data.sessionId is string
                      && request.resource.data.sessionId.size() < 50
                      && request.resource.data.event is string
                      && request.resource.data.event.size() < 30
                      && request.resource.data.keys().size() < 15;
        allow read:   if isAdmin();
        allow update, delete: if false;
      }
    }

    // ══════════════════════════════════════════════════════
    //  USER DATA — מידע אישי של לקוחות
    // ══════════════════════════════════════════════════════
    match /artifacts/{appId}/users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      match /orders/{orderId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if isAdmin();
      }

      match /assignedCoupons/{couponId} {
        allow read:  if isOwner(uid);
        allow write: if isAdmin();
      }
    }

    // ══════════════════════════════════════════════════════
    //  DENY ALL OTHER PATHS — חסימת כל השאר
    // ══════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
